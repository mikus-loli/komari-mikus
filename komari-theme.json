{
    "name": "Komari Mikus",
    "short": "Mikus",
    "description": "一个现代化、优雅的 Komari 监控主题，支持明暗主题切换、网格/表格双视图、WebSocket 实时监控和响应式设计",
    "version": "1.0.0",
    "author": "Miku",
    "url": "https://github.com/komari-monitor/komari",
    "preview": "preview.png",
    "configuration": {
        "type": "managed",
        "name": "Mikus 设置",
        "data": [
            { "name": "外观设置", "type": "title" },
            { "key": "default_theme", "name": "默认主题", "type": "select", "options": "浅色,深色,跟随系统", "default": "跟随系统", "help": "首次访问者的默认颜色主题" },
            { "key": "default_view", "name": "默认视图", "type": "select", "options": "网格,表格", "default": "网格", "help": "默认的节点展示模式" },
            { "name": "显示设置", "type": "title" },
            { "key": "show_uptime", "name": "显示运行时间", "type": "switch", "default": true, "help": "在节点卡片上显示服务器运行时间" },
            { "key": "show_network_speed", "name": "显示网络速度", "type": "switch", "default": true, "help": "显示实时网络上传/下载速度" },
            { "key": "show_ping", "name": "显示网络延迟", "type": "switch", "default": true, "help": "显示节点网络延迟（Ping）" },
            { "key": "show_connections", "name": "显示连接数", "type": "switch", "default": false, "help": "显示 TCP/UDP 连接数量" },
            { "key": "refresh_interval", "name": "刷新间隔（秒）", "type": "number", "default": 2, "help": "WebSocket 数据刷新间隔" },
            { "name": "页脚设置", "type": "title" },
            { "key": "custom_footer", "name": "自定义页脚文本", "type": "string", "default": "", "help": "在页脚显示的附加文本" }
        ]
    }
}
