    "configuration": {
        "type": "managed",
        "name": "Mikus Settings",
        "data": [
            { "name": "Appearance", "type": "title" },
            { "key": "default_theme", "name": "Default Theme", "type": "select", "options": "light,dark,system", "default": "system", "help": "Default color theme for first-time visitors" },
            { "key": "default_view", "name": "Default View", "type": "select", "options": "grid,table", "default": "grid", "help": "Default node display mode" },
            { "name": "Display", "type": "title" },
            { "key": "show_uptime", "name": "Show Uptime", "type": "switch", "default": true, "help": "Display server uptime on node cards" },
            { "key": "show_network_speed", "name": "Show Network Speed", "type": "switch", "default": true, "help": "Display real-time network upload/download speed" },
            { "key": "refresh_interval", "name": "Refresh Interval (seconds)", "type": "number", "default": 2, "help": "WebSocket data refresh interval" },
            { "name": "Footer", "type": "title" },
            { "key": "custom_footer", "name": "Custom Footer Text", "type": "string", "default": "", "help": "Additional text displayed in the footer" }
        ]
    }
