                    "options": {
                        "grid": "Grid",
                        "table": "Table"
                    }
                },
                "show_uptime": {
                    "name": "Show Uptime",
                    "help": "Display server uptime on node cards"
                },
                "show_network_speed": {
                    "name": "Show Network Speed",
